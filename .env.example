# --- Обязательно в production ---
# Секрет подписи JWT (≥32 символов). Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=замените-на-длинную-случайную-строку

# Разрешённые origin фронта (через запятую, без пробелов или с пробелами — обрежутся).
# Пример: https://mysite.ru,https://www.mysite.ru
# В development можно не задавать: тогда разрешены localhost и частные IP (для Vite с телефона в Wi‑Fi).
CORS_ORIGINS=

# --- Сервер ---
PORT=3000
# В проде за nginx удобно: HOST=127.0.0.1 (наружу только прокси). Для одного процесса без nginx: 0.0.0.0
HOST=0.0.0.0

# Раздача собранного фронта (NODE_ENV=production): по умолчанию папка dist рядом с server/
# SERVE_SPA=0 — не отдавать SPA (если статику раздаёт nginx)
# DIST_PATH=/abs/path/to/dist

# За reverse-proxy (nginx): доверять X-Forwarded-* для корректного IP в rate limit
# TRUST_PROXY=1

# --- Админы по email (через запятую) ---
# ADMIN_EMAILS=you@example.com,other@example.com

# --- Подписка без реальной оплаты (только для отладки production) ---
# В NODE_ENV=production активация «в один клик» выключена. Чтобы временно включить тест:
# ALLOW_MOCK_SUBSCRIPTION=true

# --- Лимиты (необязательно) ---
# RATE_LIMIT_AUTH_MAX=50
# RATE_LIMIT_API_MAX=400
# AUTH_MIN_PASSWORD_LENGTH=8

# Публичный URL фронта (без слэша в конце) — для ссылки сброса пароля в логах сервера.
# Пример в LAN: http://192.168.1.10:5173
# APP_PUBLIC_URL=http://127.0.0.1:5173
#
# Публичный URL API для OAuth (куда провайдер вернёт браузер). В dev без nginx:
# OAUTH_SERVER_PUBLIC_URL=http://127.0.0.1:3000
# В production: https://api.ваш-домен.ru
#
# Google: https://console.cloud.google.com/apis/credentials — redirect URI:
#   {OAUTH_SERVER_PUBLIC_URL}/api/auth/oauth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
#
# VK: https://dev.vk.com/admin/apps — redirect URI:
#   {OAUTH_SERVER_PUBLIC_URL}/api/auth/oauth/vk/callback
# VK_CLIENT_ID=
# VK_CLIENT_SECRET=
#
# Яндекс: https://oauth.yandex.ru/ — Callback URI:
#   {OAUTH_SERVER_PUBLIC_URL}/api/auth/oauth/yandex/callback
# YANDEX_CLIENT_ID=
# YANDEX_CLIENT_SECRET=
# В production при отладке можно включить вывод ссылки сброса в консоль (осторожно):
# LOG_PASSWORD_RESET_LINK=1
# RATE_LIMIT_FORGOT_MAX=20

# --- Прямые эфиры (LiveKit, опционально) ---
# Без этих переменных раздел «Прямой эфир» покажет инструкцию по настройке.
# Разверните сервер LiveKit: https://docs.livekit.io/home/self-hosting/deployment/
# LIVEKIT_URL=wss://livekit.example.com
# LIVEKIT_API_KEY=APIxxxxxxxx
# LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Фронтенд (сборка / другой домен) ---
# VITE_API_URL=https://api.example.com
# В dev без VITE_API_URL запросы идут на тот же хост, что у Vite (/api проксируется на API).
