# --- Обязательно в production (сервер API) ---
# Секрет подписи JWT (≥32 символов). Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=замените-на-длинную-случайную-строку

# Разрешённые origin фронта (через запятую). В production список обязателен.
# Пример один домен: https://mysite.ru
# Фронт на GitHub Pages + локальная разработка (Vite):
#   https://USERNAME.github.io,http://127.0.0.1:5173,http://localhost:5173
# Origin для Pages — только схема+хост (без пути): https://domvverhdnom.github.io
CORS_ORIGINS=

# --- Сервер ---
PORT=3000
# В проде за nginx удобно: HOST=127.0.0.1 (наружу только прокси). Для одного процесса без nginx: 0.0.0.0
HOST=0.0.0.0

# Раздача собранного фронта (NODE_ENV=production): по умолчанию папка dist рядом с server/
# SERVE_SPA=0 — не отдавать SPA (если статику раздаёт nginx или фронт на GitHub Pages)
# DIST_PATH=/abs/path/to/dist

# За reverse-proxy (nginx): доверять X-Forwarded-* для корректного IP в rate limit
# TRUST_PROXY=1

# --- Админы по email (через запятую) ---
# ADMIN_EMAILS=you@example.com,other@example.com

# --- Подписка без реальной оплаты (только для отладки production) ---
# В NODE_ENV=production активация «в один клик» выключена. Чтобы временно включить тест:
# ALLOW_MOCK_SUBSCRIPTION=true

# --- Лимиты (необязательно) ---
# RATE_LIMIT_AUTH_MAX=50
# RATE_LIMIT_API_MAX=400
# AUTH_MIN_PASSWORD_LENGTH=8

# Публичный URL фронта (без слэша в конце) — ссылки сброса пароля, редиректы OAuth в браузере.
# Локально: http://127.0.0.1:5173
# Фронт только на GitHub Pages: https://USERNAME.github.io/REPO-NAME  (без слэша в конце)
# APP_PUBLIC_URL=http://127.0.0.1:5173

# Публичный URL API (куда провайдеры OAuth отдают callback). Обычно совпадает с тем, что в VITE_API_URL.
# Локально: http://127.0.0.1:3000
# Production: https://api.ваш-домен.ru
# OAUTH_SERVER_PUBLIC_URL=http://127.0.0.1:3000
#
# Google: https://console.cloud.google.com/apis/credentials — redirect URI:
#   {OAUTH_SERVER_PUBLIC_URL}/api/auth/oauth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
#
# VK: https://dev.vk.com/admin/apps — redirect URI:
#   {OAUTH_SERVER_PUBLIC_URL}/api/auth/oauth/vk/callback
# VK_CLIENT_ID=
# VK_CLIENT_SECRET=
#
# Яндекс: https://oauth.yandex.ru/ — Callback URI:
#   {OAUTH_SERVER_PUBLIC_URL}/api/auth/oauth/yandex/callback
# YANDEX_CLIENT_ID=
# YANDEX_CLIENT_SECRET=
# В production при отладке можно включить вывод ссылки сброса в консоль (осторожно):
# LOG_PASSWORD_RESET_LINK=1
# RATE_LIMIT_FORGOT_MAX=20

# --- Прямые эфиры (LiveKit, опционально) ---
# LIVEKIT_URL=wss://livekit.example.com
# LIVEKIT_API_KEY=APIxxxxxxxx
# LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ═══ Фронт на GitHub Pages, API на отдельном хосте ═══
#
# 1) Репозиторий → Settings → Secrets and variables → Actions → New repository secret:
#    Name:  VITE_API_URL
#    Value: https://api.ваш-домен.ru   (без слэша в конце; тот же хост, что у вашего Express)
#
# 2) На сервере API в production в .env:
#    CORS_ORIGINS=https://USERNAME.github.io
#    APP_PUBLIC_URL=https://USERNAME.github.io/REPO-NAME
#    OAUTH_SERVER_PUBLIC_URL=https://api.ваш-домен.ru
#
# 3) Локальная сборка как в CI (проверка перед пушем):
#    VITE_GH_PAGES_BASE=/REPO-NAME/ VITE_API_URL=https://api.ваш-домен.ru npm run build
#
# База URL для fetch/socket на клиенте (встраивается при vite build). В dev не нужен — работает прокси Vite.
# VITE_API_URL=https://api.example.com
