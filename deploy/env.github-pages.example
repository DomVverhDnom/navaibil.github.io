# Фрагмент для .env на VPS, когда фронт на GitHub Pages, API на этом сервере за nginx+HTTPS.
# Подставьте свой домен API и при необходимости URL Pages (если другой репозиторий/пользователь).

HOST=127.0.0.1
PORT=3000
TRUST_PROXY=1

# Только схема+хост страницы Pages (без пути /repo/)
CORS_ORIGINS=https://domvverhdnom.github.io

# Полный URL фронта (со путём project pages, если есть)
APP_PUBLIC_URL=https://domvverhdnom.github.io/navaibil.github.io

# Публичный URL API (совпадает с VITE_API_URL на GitHub Secrets)
OAUTH_SERVER_PUBLIC_URL=https://api.ВАШ-ДОМЕН.ru

# JWT_SECRET, ADMIN_EMAILS и т.д. — как в основном .env.example
