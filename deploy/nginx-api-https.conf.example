# Пример для API на поддомене (HTTPS выдаст certbot --nginx).
# Скопируйте: sudo cp deploy/nginx-api-https.conf.example /etc/nginx/sites-available/vibetelegram-api
# Замените api.ВАШ-ДОМЕН.ru на реальный FQDN, затем:
#   sudo ln -sf /etc/nginx/sites-available/vibetelegram-api /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#   sudo certbot --nginx -d api.ВАШ-ДОМЕН.ru

upstream vibe_node {
    server 127.0.0.1:3000;
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name api.ВАШ-ДОМЕН.ru;

    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name api.ВАШ-ДОМЕН.ru;

    # После certbot сюда подставятся ssl_certificate и ssl_certificate_key

    client_max_body_size 50m;

    location / {
        proxy_pass http://vibe_node;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /socket.io/ {
        proxy_pass http://vibe_node;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
    }
}
