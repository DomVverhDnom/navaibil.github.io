# Пример для Ubuntu/Debian: скопируйте в /etc/nginx/sites-available/ и подставьте домен и пути к сертификатам.
# certbot --nginx -d example.ru -d www.example.ru
#
# Вариант A — всё через Node (Node раздаёт dist + API): один proxy на порт приложения.
# Вариант B — статика из dist nginx’ом, API/WebSocket на Node (тогда в .env SERVE_SPA=0).

upstream vibetelegram_node {
    server 127.0.0.1:3000;
    keepalive 8;
}

server {
    listen 80;
    listen [::]:80;
    server_name example.ru www.example.ru;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name example.ru www.example.ru;

    ssl_certificate     /etc/letsencrypt/live/example.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/example.ru/privkey.pem;

    client_max_body_size 12m;

    # --- Вариант A: один прокси на приложение ---
    location / {
        proxy_pass http://vibetelegram_node;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 86400;
    }

    # --- Вариант B (раскомментируйте и отключите блок выше location /): статика с диска ---
    # root /var/www/vibetelegram/dist;
    # location /assets/ {
    #     add_header Cache-Control "public, max-age=31536000, immutable";
    # }
    # location = /index.html {
    #     add_header Cache-Control "no-store";
    # }
    # location / {
    #     try_files $uri $uri/ /index.html;
    # }
    # location /api/ {
    #     proxy_pass http://vibetelegram_node;
    #     proxy_http_version 1.1;
    #     proxy_set_header Host $host;
    #     proxy_set_header X-Real-IP $remote_addr;
    #     proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    #     proxy_set_header X-Forwarded-Proto $scheme;
    # }
    # location /socket.io/ {
    #     proxy_pass http://vibetelegram_node;
    #     proxy_http_version 1.1;
    #     proxy_set_header Upgrade $http_upgrade;
    #     proxy_set_header Connection "upgrade";
    #     proxy_set_header Host $host;
    #     proxy_read_timeout 86400;
    # }
    # location /uploads/ {
    #     proxy_pass http://vibetelegram_node;
    #     proxy_set_header Host $host;
    # }
}
